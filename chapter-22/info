  1 -> miss -> 1
  2 -> miss -> 1,2
  3 -> miss -> 1,2,3
  4 -> miss -> 2,3,4
  1 -> miss -> 3,4,1
  2 -> miss -> 4,1,2
  5 -> miss -> 1,2,5
  1 -> hit -> 1,2,5
